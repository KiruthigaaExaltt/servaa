{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file-if-exists=.env --import tsx ./src/index.ts",
    "seed": "tsx --env-file-if-exists=.env --tsconfig ../servaa/tsconfig.json ../../lib/db/src/seed.ts",
    "build": "node ./build.mjs",
    "start": "node --env-file-if-exists=.env --enable-source-maps ./dist/index.mjs",
    "start:production": "pnpm --filter @workspace/db run seed && node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
    ,"test": "pnpm --filter @workspace/db exec tsx --test ../../artifacts/api-server/src/**/*.test.ts"
  },
  "dependencies": {
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "express": "^5",
    "pino": "^9",
    "pino-http": "^10"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
